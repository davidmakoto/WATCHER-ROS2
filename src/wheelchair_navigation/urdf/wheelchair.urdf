<?xml version="1.0"?>
<robot name="wheelchair">

    <material name="grey">
        <color rgba="0.7 0.7 0.7 1"/>
    </material>
    
    <material name="green">
        <color rgba="0 0.6 0 1"/>
    </material>

    <!-- Base footprint - reference frame on ground -->
    <link name="base_footprint">
        <inertial>
            <mass value="0.001"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0"
                    iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <!-- Main chassis -->
    <link name="base_link">
        <visual>
            <geometry>
                <box size="0.60 0.645 0.25"/>
            </geometry>
            <origin xyz="-0.05 0 0" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
        <collision>
            <geometry>
                <box size="0.60 0.645 0.25"/>
            </geometry>
            <origin xyz="-0.05 0 0" rpy="0 0 0"/>
        </collision>
        <inertial>
            <mass value="10.0"/>
            <origin xyz="-0.05 0 0" rpy="0 0 0"/>
            <inertia ixx="0.5" ixy="0.0" ixz="0.0"
                    iyy="0.5" iyz="0.0" izz="0.5"/>
        </inertial>

        <!-- Side rails -->
        <visual>
            <geometry>
                <box size="0.30 0.08 0.08"/>
            </geometry>
            <origin xyz="-0.3325 0.24 -0.085" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
        <visual>
            <geometry>
                <box size="0.30 0.08 0.08"/>
            </geometry>
            <origin xyz="-0.3325 -0.24 -0.085" rpy="0 0 0"/>
            <material name="green"/>
        </visual>

        <!-- Front supports -->
        <visual>
            <geometry>
                <box size="0.06 0.08 0.08"/>
            </geometry>
            <origin xyz="0.28 0.24 -0.085" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
        <visual>
            <geometry>
                <box size="0.06 0.08 0.08"/>
            </geometry>
            <origin xyz="0.28 -0.24 -0.085" rpy="0 0 0"/>
            <material name="green"/>
        </visual>

        <!-- Backrest -->
        <visual>
            <geometry>
                <box size="0.04 0.40 0.55"/>
            </geometry>
            <origin xyz="-0.33 0 0.400" rpy="0 0 0"/>
            <material name="green"/>
        </visual>
    </link>

    <!-- Left drive wheel -->
    <link name="left_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.178" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.178" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
        </collision>
        <inertial>
            <mass value="0.5"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" 
                    iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <!-- Right drive wheel -->
    <link name="right_wheel">
        <visual>
            <geometry>
                <cylinder radius="0.178" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry>
                <cylinder radius="0.178" length="0.05"/>
            </geometry>
            <origin xyz="0 0 0" rpy="1.5708 0 0" />
        </collision>
        <inertial>
            <mass value="0.5"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" 
                    iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <!-- Casters -->
    <link name="left_front_caster">
        <visual>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
                    iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="right_front_caster">
        <visual>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
                    iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="left_rear_caster">
        <visual>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
                    iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <link name="right_rear_caster">
        <visual>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <material name="grey" />
        </visual>
        <collision>
            <geometry><sphere radius="0.05" /></geometry>
            <origin xyz="0 0 0" rpy="0 0 0" />
        </collision>
        <inertial>
            <mass value="0.1"/>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <inertia ixx="0.0001" ixy="0.0" ixz="0.0" 
                    iyy="0.0001" iyz="0.0" izz="0.0001"/>
        </inertial>
    </link>

    <!-- Lidar sensor -->
    <link name="lidar_link">
        <visual>
            <geometry><cylinder radius="0.05" length="0.05"/></geometry>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <material name="grey"/>
        </visual>
        <collision>
            <geometry><cylinder radius="0.05" length="0.05"/></geometry>
        </collision>
        <inertial>
            <mass value="0.1"/>
            <inertia ixx="0.001" ixy="0.0" ixz="0.0" 
                    iyy="0.001" iyz="0.0" izz="0.001"/>
        </inertial>
    </link>

    <!-- Joints -->
    <joint name="base_joint" type="fixed">
        <parent link="base_footprint" />
        <child link="base_link"/>
        <origin xyz="0 0 0.20" rpy="0 0 0" />
    </joint>

    <joint name="base_left_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="left_wheel"/>
        <origin xyz="0.0 0.3475 -0.036" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="base_right_wheel_joint" type="continuous">
        <parent link="base_link" />
        <child link="right_wheel"/>
        <origin xyz="0.0 -0.3475 -0.036" rpy="0 0 0" />
        <axis xyz="0 1 0" />
    </joint>

    <joint name="left_front_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="left_front_caster" />
        <origin xyz="0.30 0.24 -0.164" rpy="0 0 0" />
    </joint>

    <joint name="right_front_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="right_front_caster" />
        <origin xyz="0.30 -0.24 -0.164" rpy="0 0 0" />
    </joint>

    <joint name="left_rear_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="left_rear_caster" />
        <origin xyz="-0.41 0.24 -0.164" rpy="0 0 0" />
    </joint>

    <joint name="right_rear_caster_joint" type="fixed">
        <parent link="base_link" />
        <child link="right_rear_caster" />
        <origin xyz="-0.41 -0.24 -0.164" rpy="0 0 0" />
    </joint>

    <joint name="lidar_joint" type="fixed">
        <parent link="base_link"/>
        <child link="lidar_link"/>
        <origin xyz="0 0 0.20" rpy="0 0 0"/>
    </joint>

    <!-- Gazebo plugins -->
    <gazebo reference="lidar_link">
        <sensor name="lidar" type="gpu_lidar">
            <topic>scan</topic>
            <update_rate>10</update_rate>
            <lidar>
                <scan>
                    <horizontal>
                        <samples>360</samples>
                        <resolution>1.0</resolution>
                        <min_angle>-3.14159</min_angle>
                        <max_angle>3.14159</max_angle>
                    </horizontal>
                </scan>
                <range>
                    <min>0.12</min>
                    <max>10.0</max>
                    <resolution>0.01</resolution>
                </range>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.01</stddev>
                </noise>
            </lidar>
            <always_on>1</always_on>
            <visualize>true</visualize>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>base_left_wheel_joint</left_joint>
            <right_joint>base_right_wheel_joint</right_joint>
            <wheel_separation>0.695</wheel_separation>
            <wheel_radius>0.178</wheel_radius>
            <odom_publish_frequency>50</odom_publish_frequency>
            <topic>cmd_vel</topic>
            <odom_topic>odom</odom_topic>
            <frame_id>odom</frame_id>
            <child_frame_id>base_footprint</child_frame_id>
        </plugin>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
        </plugin>
    </gazebo>

    <!-- Gazebo materials and friction -->
    <gazebo reference="left_wheel">
        <material>Gazebo/Grey</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>
    
    <gazebo reference="right_wheel">
        <material>Gazebo/Grey</material>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>
    
    <gazebo reference="base_link">
        <material>Gazebo/Green</material>
    </gazebo>

</robot>
